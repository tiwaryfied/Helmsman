# =========================================================
# Helmsman backend configuration
# =========================================================

# --- LLM provider keys ---
# Helmsman supports Gemini, Anthropic, and OpenAI. Set whichever you have.
# If multiple are set, Helmsman picks in this order (auto):
#     Gemini > Anthropic > OpenAI
# Override with HELMSMAN_LLM_PROVIDER below.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Models per provider (defaults shown)
HELMSMAN_GEMINI_MODEL=gemini-2.5-flash
HELMSMAN_ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
HELMSMAN_OPENAI_MODEL=gpt-4o-mini

# Force a specific provider (auto | gemini | anthropic | openai)
HELMSMAN_LLM_PROVIDER=auto

# --- Coral ---
# Path to the coral binary. Auto-detected at $HOME/.local/bin/coral if unset.
CORAL_BIN=

# --- Helmsman runtime ---
# Backend port
HELMSMAN_PORT=8787

# Optional: pin the session-cookie + token-encryption secret. If unset,
# Helmsman creates one at backend/.helmsman_secret on first start and reuses
# it across runs. Override only if you want to rotate or share an explicit
# value across machines.
#HELMSMAN_SESSION_SECRET=

# --- Legacy single-user mode (still respected by `coral` SQL fallbacks) ---
# Per-user identity now lives in Helmsman's own auth (SQLite users table) and
# per-source connect/demo state is managed in the in-app Onboarding flow.
# These are only used when running unauthenticated SQL via the CLI / tests.
HELMSMAN_MODE=demo
HELMSMAN_CAPTAIN=captain
HELMSMAN_CAPTAIN_EMAIL=captain@coralreef.dev
